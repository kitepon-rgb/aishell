{
  "schema": "aishell.workspace-checkpoint-cases.v1",
  "contract": "docs/adr/0006-persistent-workspace-checkpoint-contract.md",
  "cases": [
    {
      "id": "cold-start-missing",
      "condition": "checkpoint_missing",
      "expected": { "decision": "explicit_full_snapshot_required", "typed_error": null, "reuse_entries": false }
    },
    {
      "id": "warm-restore-unchanged",
      "condition": "identity_schema_exclusion_and_event_history_match",
      "expected": { "decision": "warm_restore", "typed_error": null, "reuse_entries": true, "rehash": [] }
    },
    {
      "id": "offline-modify",
      "condition": "continuous_event_replay_names_modified_path",
      "expected": { "decision": "warm_restore", "typed_error": null, "reuse_entries": true, "rehash": ["Sources/App.swift"] }
    },
    {
      "id": "offline-same-size-mtime-modify",
      "condition": "metadata_matches_but_continuous_event_replay_names_path",
      "expected": { "decision": "warm_restore", "typed_error": null, "reuse_entries": true, "rehash": ["State.bin"] }
    },
    {
      "id": "offline-create-delete-rename",
      "condition": "tree_metadata_and_replay_show_create_delete_and_stable_identity_rename",
      "expected": { "decision": "warm_restore", "typed_error": null, "reuse_entries": true, "changes": ["created", "deleted", "renamed"] }
    },
    {
      "id": "event-gap",
      "condition": "event_history_is_not_continuous",
      "expected": { "decision": "stop", "typed_error": "RESCAN_REQUIRED", "reuse_entries": false }
    },
    {
      "id": "root-replaced",
      "condition": "root_device_or_inode_changed",
      "expected": { "decision": "stop", "typed_error": "RESCAN_REQUIRED", "reuse_entries": false }
    },
    {
      "id": "corrupt-payload",
      "condition": "payload_sha256_mismatch_or_decode_failure",
      "expected": { "decision": "stop", "typed_error": "CHECKPOINT_CORRUPT", "reuse_entries": false, "preserve_checkpoint": true }
    },
    {
      "id": "unsupported-schema",
      "condition": "no_explicit_migrator_for_schema",
      "expected": { "decision": "stop", "typed_error": "CHECKPOINT_UNSUPPORTED", "reuse_entries": false, "preserve_checkpoint": true }
    },
    {
      "id": "migration-failed",
      "condition": "explicit_migrator_cannot_produce_valid_target",
      "expected": { "decision": "stop", "typed_error": "CHECKPOINT_MIGRATION_FAILED", "reuse_entries": false, "preserve_checkpoint": true }
    },
    {
      "id": "single-root-quota-exceeded",
      "condition": "encoded_bytes_or_entry_count_exceeds_per_root_limit",
      "expected": { "decision": "stop", "typed_error": "CHECKPOINT_QUOTA_EXCEEDED", "reuse_entries": false, "preserve_previous": true }
    },
    {
      "id": "atomic-replace-failed",
      "condition": "fsync_or_atomic_replace_fails",
      "expected": { "decision": "stop", "typed_error": "CHECKPOINT_WRITE_FAILED", "reuse_entries": false, "preserve_previous": true }
    }
  ]
}
