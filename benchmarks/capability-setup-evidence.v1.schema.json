{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "type":"object","additionalProperties":false,
  "required":["schema","taskId","workspaceRoot","preStateDigest"],
  "properties":{
    "schema":{"const":"aishell.benchmark-setup-evidence.v1"},
    "taskId":{"type":"string","minLength":1},"workspaceRoot":{"type":"string","minLength":1},
    "preStateDigest":{"type":"string","pattern":"^[a-f0-9]{64}$"},
    "checkpoint":{"type":"string","minLength":1},"cursor":{"type":"string","minLength":1},
    "runId":{"type":"string","minLength":1},
    "handles":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","pattern":"^art_[a-z0-9_-]+$"}}
  }
}
