  "contracts": [
    {"taskId":"workspace-persistence-warm-restore","setupSteps":["materialize fixture including generated seed","start AIShell and create a full workspace checkpoint","stop AIShell without changing fixture"],"timedSteps":["start the measured arm","submit the frozen model prompt","record filesystem scan and result telemetry until completion"]},
    {"taskId":"workspace-persistence-offline-change","setupSteps":["materialize fixture including generated seed","start AIShell and create a full workspace checkpoint","stop AIShell","apply the frozen offline mutation"],"timedSteps":["start the measured arm","submit the frozen model prompt","record changed paths and fallback telemetry"]},
    {"taskId":"git-diff-context-staged-rename","setupSteps":["materialize fixture and initialize Git main","commit seed files","apply and stage the frozen rename"],"timedSteps":["submit the frozen model prompt","capture porcelain-v2 Git evidence","record the reported rename"]},
    {"taskId":"git-diff-context-mixed-state","setupSteps":["materialize fixture and initialize Git main","commit seed files","apply the frozen unstaged edit and new file"],"timedSteps":["submit the frozen model prompt","capture Git and filesystem evidence","record continuation tokens"]},
    {"taskId":"project-profile-warm-hit","setupSteps":["materialize fixture","discover the project profile once","persist the profile cache"],"timedSteps":["submit the frozen model prompt","record returned commands and cache decision"]},
    {"taskId":"project-profile-manifest-change","setupSteps":["materialize fixture","discover and persist the initial profile","apply the frozen manifest mutation"],"timedSteps":["submit the frozen model prompt","record returned commands and invalidation decision"]},
    {"taskId":"batch-context-multi-query","setupSteps":["materialize fixture including the 2000-file generated tree"],"timedSteps":["submit the frozen model prompt with the three target queries","record paths and duplicate identities"]},
    {"taskId":"batch-context-shared-budget","setupSteps":["materialize fixture including the 2000-file generated tree","set the frozen 16384-byte shared budget"],"timedSteps":["submit the frozen model prompt","follow returned continuation to exhaustion","record budget accounting"]},
    {"taskId":"freshness-cache-repeat-check","setupSteps":["materialize fixture","execute the check once and retain its freshness inputs"],"timedSteps":["submit the frozen repeat prompt without mutation","record process executions and cache evidence"]},
    {"taskId":"freshness-cache-input-change","setupSteps":["materialize fixture","execute the check once and retain its freshness inputs","apply the frozen source mutation"],"timedSteps":["submit the frozen repeat prompt","record process executions and cache evidence"]},
    {"taskId":"change-impact-direct-dependent","setupSteps":["materialize fixture","index static imports","apply the frozen export mutation"],"timedSteps":["submit the frozen model prompt","record affected nodes and provenance"]},
    {"taskId":"change-impact-unresolved-edge","setupSteps":["materialize fixture","apply the frozen dynamic import mutation"],"timedSteps":["submit the frozen model prompt","record unknown edges and completeness claims"]},
    {"taskId":"focused-pipeline-recommend-only","setupSteps":["materialize fixture","apply the frozen source mutation"],"timedSteps":["submit the recommendation-only prompt","record recommendations and all spawned processes"]},
    {"taskId":"focused-pipeline-explicit-run","setupSteps":["materialize fixture","apply the frozen source mutation"],"timedSteps":["submit the frozen prompt without execution consent","record recommendations and whether execution is gated"]},
    {"taskId":"async-process-first-useful-result","setupSteps":["materialize the deterministic 10-second process fixture"],"timedSteps":["submit the frozen model prompt","timestamp first diagnostic","wait for and record terminal state"]},
    {"taskId":"async-process-cancel","setupSteps":["materialize the deterministic 10-second process fixture"],"timedSteps":["submit the frozen model prompt","request cancellation after first diagnostic","inspect the process group for orphans"]},
    {"taskId":"artifact-query-cross-run-search","setupSteps":["materialize and import both fixture logs as distinct retained runs"],"timedSteps":["submit the frozen model prompt","record matching run IDs and ranges"]},
    {"taskId":"artifact-query-history-diff","setupSteps":["materialize and import both fixture logs as distinct retained runs"],"timedSteps":["submit the frozen model prompt","record diff groups","verify raw handles remain readable"]},
    {"taskId":"workspace-wait-external-edit","setupSteps":["materialize fixture","capture the starting cursor","schedule the frozen delayed write outside the measured agent"],"timedSteps":["submit the frozen wait prompt","record poll syscalls and returned delta"]},
    {"taskId":"workspace-wait-event-gap","setupSteps":["materialize fixture","capture the starting cursor","inject the frozen event-gap marker"],"timedSteps":["submit the frozen wait prompt","record typed error and scan count"]},
    {"taskId":"change-set-atomic-success","setupSteps":["materialize fixture","capture SHA-256 for both target files","bind the frozen replacement contents to those SHAs"],"timedSteps":["submit the prompt containing paths, SHAs, and replacement contents","record filesystem transaction evidence"]},
    {"taskId":"change-set-stale-sha","setupSteps":["materialize fixture","capture SHA-256 for both target files","apply the frozen external mutation after SHA capture","bind the requested replacements to the old SHAs"],"timedSteps":["submit the prompt containing paths, stale SHAs, and replacement contents","record error and unchanged-file evidence"]},
    {"taskId":"diagnostic-adapter-known-format","setupSteps":["materialize fixture","register the fixture-json adapter"],"timedSteps":["submit the frozen parse prompt","record structured diagnostics and provenance"]},
    {"taskId":"diagnostic-adapter-malformed-format","setupSteps":["materialize fixture","register the fixture-json adapter","apply the frozen malformed input mutation"],"timedSteps":["submit the frozen parse prompt","record typed error and fallback count"]},
    {"taskId":"semantic-context-fresh-reference","setupSteps":["materialize fixture","build the semantic index at the current workspace cursor"],"timedSteps":["submit the frozen reference prompt","record references and freshness proof"]},
    {"taskId":"semantic-context-stale-after-edit","setupSteps":["materialize fixture","build the semantic index","apply the frozen symbol mutation without reindexing"],"timedSteps":["submit the frozen reference prompt","record freshness and fallback count"]},
    {"taskId":"dependency-provider-depfile-impact","setupSteps":["materialize fixture","register and parse the depfile provider","apply the frozen header mutation"],"timedSteps":["submit the frozen impact prompt","record affected paths and depfile provenance"]},
    {"taskId":"dependency-provider-missing-evidence","setupSteps":["materialize fixture","apply the frozen depfile deletion"],"timedSteps":["submit the frozen impact prompt","record unknown edges and completeness claims"]},
    {"taskId":"worktree-compare-branch-diff","setupSteps":["materialize fixture and initialize Git main","commit seed files","create candidate worktree and apply the frozen branch mutation"],"timedSteps":["submit the frozen comparison prompt","record Git base and changed paths"]},
    {"taskId":"worktree-compare-dirty-worktree","setupSteps":["materialize fixture and initialize Git main","commit seed files","apply the frozen dirty mutation"],"timedSteps":["submit the frozen comparison prompt","record dirty state, changed paths, and budget accounting"]},
    {"taskId":"bilingual-workflow-english","setupSteps":["materialize fixture","capture baseline and starting cursor","schedule the delayed write outside the measured agent"],"timedSteps":["submit the frozen English prompt","record wait trace and final JSON report"]},
    {"taskId":"bilingual-workflow-japanese","setupSteps":["materialize fixture","capture pre-state SHA for both target files"],"timedSteps":["submit the frozen Japanese prompt","record atomic filesystem transaction and final JSON report"]}
  ]
